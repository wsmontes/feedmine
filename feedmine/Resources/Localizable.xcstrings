    "Colors and typography shift subtly with the time of day.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Colors and typography shift subtly with the time of day."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الألوان والطباعة تتغير برفق مع وقت اليوم."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Colores y tipografía cambian sutilmente con la hora del día."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Barvy a typografie se jemně mění během dne."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Farver og typografi skifter subtilt med tidspunktet på dagen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Farben und Typografie ändern sich mit der Tageszeit."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τα χρώματα και η τυπογραφία αλλάζουν διακριτικά με την ώρα της ημέρας."
          }

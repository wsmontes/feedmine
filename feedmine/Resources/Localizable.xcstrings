    "All caught up. Sleep well. The news will be here tomorrow.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All caught up. Sleep well. The news will be here tomorrow."
          }
        },
        "ar": {

    "Disabled sources are skipped during feed fetching. Changes take effect on next refresh.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Disabled sources are skipped during feed fetching. Changes take effect on next refresh."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المصادر المعطلة تُتخطى. التغييرات عند التحديث التالي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Las fuentes desactivadas se omiten durante la búsqueda. Los cambios surten efecto en la próxima actualización."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vypnuté zdroje jsou přeskočeny. Změny při dalším obnovení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktiverede kilder springes over under feed-hentning. Ændringer træder i kraft ved næste opdatering."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivierte Quellen werden beim Abrufen übersprungen. Änderungen werden bei der nächsten Aktualisierung wirksam."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι απενεργοποιημένες πηγές παραλείπονται κατά τη φόρτωση. Οι αλλαγές ισχύουν στην επόμενη ενημέρωση."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Disabled sources are skipped during feed fetching. Changes take effect on next refresh."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Disabled sources are skipped during feed fetching. Changes take effect on next refresh."
          }
        },
        "en-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "Disabled sources are skipped during feed fetching. Changes take effect on next refresh."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Las fuentes desactivadas se omiten durante la búsqueda. Los cambios surten efecto en la próxima actualización."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las fuentes desactivadas se omiten durante la búsqueda. Los cambios surten efecto en la próxima actualización."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Poistetut lähteet ohitetaan syötteiden haussa. Muutokset tulevat voimaan seuraavassa päivityksessä."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Les sources désactivées sont ignorées lors de la récupération. Les changements prennent effet à la prochaine actualisation."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les sources désactivées sont ignorées lors de la récupération. Les changements prennent effet à la prochaine actualisation."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מקורות מושבתים מדולגים בזמן משיכת הזנות. השינויים ייכנסו לתוקף ברענון הבא."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अक्षम स्रोत छोड़ दिए जाएंगे। अगले रिफ्रेश पर बदलाव लागू होंगे।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Onemogućeni izvori se preskaču. Promjene pri sljedećem osvježavanju."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A letiltott források kihagyásra kerülnek a feed letöltésekor. A változások a következő frissítéskor lépnek életbe."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dinonaktifkan sumber pada"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fonti disattivate saltate. Modifiche effettive al prossimo aggiornamento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無効ソースはスキップ。次回更新時に変更適用。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "비활성 소스는 건너뜁니다. 다음 새로고침에 적용."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Dilumpuhkan sumber pada"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktiverte kilder hoppes over under feed-henting. Endringer trer i kraft ved neste oppdatering."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uitgeschakelde bronnen worden overgeslagen bij het ophalen van feeds. Wijzigingen worden actief bij de volgende vernieuwing."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyłączone źródła są pomijane. Zmiany przy następnym odświeżeniu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fontes desativadas são ignoradas durante a busca. Mudanças entram em vigor na próxima atualização."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Fontes desativadas são ignoradas durante a busca. Mudanças entram em vigor na próxima atualização."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Fonti disattivate saltate. Modifiche effettive al prossimo aggiornamento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отключённые источники пропущены. Изменения при следующем обновлении."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vypnuté zdroje sú preskočené. Zmeny pri ďalšom obnovení."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inaktiverade källor hoppas över vid flödeshämtning. Ändringar träder i kraft vid nästa uppdatering."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปิดใช้งาน แหล่ง บน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Devre dışı kaynaklar besleme alımında atlanır. Değişiklikler sonraki yenilemede etkili olur."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вимкнені джерела пропускаються. Зміни при наступному оновленні."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã tắt nguồn trên"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已禁用源将被跳过。更改在下次刷新时生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已禁用源将被跳过。更改在下次刷新时生效。"
          }
        }
      }
    },

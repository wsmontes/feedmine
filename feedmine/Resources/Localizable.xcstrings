    "We are keeping you entertained while the content arrives.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We are keeping you entertained while the content arrives."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نبقيك مستمتعًا بينما يصل المحتوى."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Et mantenim entretingut mentre arriba el contingut."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zabavíme vás, než dorazí obsah."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi holder dig underholdt, mens indholdet kommer ind."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir halten dich bei Laune, während die Inhalte eintreffen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Σας κρατάμε απασχολημένους μέχρι να φτάσει το περιεχόμενο."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "We are keeping you entertained while the content arrives."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "We are keeping you entertained while the content arrives."
          }
        },
        "en-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "We are keeping you entertained while the content arrives."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Te mantenemos entretenido mientras llega el contenido."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te entretenemos mientras llega el contenido."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pidämme sinut viihdytettynä, kun sisältö saapuu."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "On vous fait patienter pendant que le contenu arrive."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "On vous fait patienter pendant que le contenu arrive."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אנחנו מעסיקים אתכם בזמן שהתוכן מגיע."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सामग्री आने तक हम आपको व्यस्त रख रहे हैं।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zabavljamo vas dok sadržaj ne stigne."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Lekötünk, amíg megérkezik a tartalom."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kami membuat Anda tetap terhibur sementara konten tiba."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ti teniamo compagnia mentre arrivano i contenuti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンテンツが届くまで、少しお付き合いください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "콘텐츠가 도착하는 동안 잠시 즐겁게 기다려 주세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Kami menghiburkan anda sementara kandungan tiba."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi holder deg underholdt mens innholdet kommer."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We houden je bezig terwijl de inhoud binnenkomt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zajmujemy Cię, zanim dotrą treści."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Estamos te entretendo enquanto o conteúdo chega."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantemo-lo entretido enquanto o conteúdo chega."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Te ținem ocupat până ajunge conținutul."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Развлекаем вас, пока загружается контент."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zabavíme vás, kým príde obsah."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi håller dig underhållen medan innehållet kommer in."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เราจะทำให้คุณเพลินระหว่างที่เนื้อหากำลังมา"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İçerik gelirken sizi oyalıyoruz."
          }
        },
        "uk": {

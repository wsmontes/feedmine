    "This will delete all bookmarks, read history, and source configuration. This cannot be undone.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will delete all bookmarks, read history, and source configuration. This cannot be undone."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيحذف الإشارات والسجل والمصادر. لا يمكن التراجع."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará todos los marcadores, historial de lectura y configuración de fuentes. No se puede deshacer."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Smaže záložky, historii a zdroje. Nevratné."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies löscht alle bogmærker, den Leseverlpå og die kilderkonfiguration. Dies kann ikke rückgängig gemacht blive."

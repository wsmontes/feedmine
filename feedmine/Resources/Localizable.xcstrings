    "All caught up. Quick and clean.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All caught up. Quick and clean."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كل شيء مقروء. سريع ونظيف."
          }
        },
        "ca": {
          "stringUnit": {

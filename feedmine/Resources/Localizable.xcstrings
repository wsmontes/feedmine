    "Swipe left on articles or use the bookmark button to save them for later.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Swipe left on articles or use the bookmark button to save them for later."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسحب لليسار أو استخدم زر الإشارة المرجعية."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Desliza hacia la izquierda en los artículos o usa el botón de marcador para guardarlos para más tarde."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přejeďte doleva nebo použijte tlačítko záložky."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Swipe til venstre på artikler eller brug bogmærkeknappen for at gemme dem til senere."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wische bei Artikeln nach links oder nutze den Lesezeichen-Button, um sie für später zu speichern."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Σύρε αριστερά στα άρθρα ή χρησιμοποίησε τον σελιδοδείκτη για αποθήκευση αργότερα."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Swipe left on articles or use the bookmark button to save them for later."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Swipe left on articles or use the bookmark button to save them for later."
          }
        },
        "en-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "Swipe left on articles or use the bookmark button to save them for later."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Desliza hacia la izquierda en los artículos o usa el botón de marcador para guardarlos para más tarde."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desliza hacia la izquierda en los artículos o usa el botón de marcador para guardarlos para más tarde."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyyhkäise artikkeleita vasemmalle tai käytä kirjanmerkkipainiketta tallentaaksesi ne myöhemmäksi."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Glissez vers la gauche sur les articles ou utilisez le bouton favori pour les sauvegarder."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Glissez vers la gauche sur les articles ou utilisez le bouton favori pour les sauvegarder."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "משוך שמאלה או או השתמש כפתור הסימנייה הסימניות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बाएं स्वाइप करें या बुकमार्क बटन का उपयोग करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prevucite lijevo ili koristite gumb za oznake."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Húzd balra a cikkeket, vagy használd a könyvjelző gombot, hogy elmentsd őket későbbre."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "lakukan atau markah"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scorri a sinistra o usa il pulsante segnalibro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "左にスワイプかブックマークボタンで後で読む。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "왼쪽으로 스와이프하거나 북마크 버튼을 사용하세요."
